{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "installCommand": "npm install",
        "buildCommand": "npm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/register",
      "dest": "/api/register.js"
    },
    {
      "src": "/api/login",
      "dest": "/api/login.js"
    },
    {
      "src": "/api/profile",
      "dest": "/api/profile.js"
    },
    {
      "src": "/api/tasks",
      "dest": "/api/tasks.js"
    },
    {
      "src": "/api/tasks",
      "dest": "/api/tasks-post.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/tasks/(.*)",
      "dest": "/api/tasks-put.js",
      "methods": ["PUT"]
    },
    {
      "src": "/api/tasks/(.*)",
      "dest": "/api/tasks-delete.js",
      "methods": ["DELETE"]
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "/api"
  }
}
